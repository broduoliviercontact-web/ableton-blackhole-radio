# ---- LiveKit (serveur uniquement — ne JAMAIS exposer côté frontend) ----
LIVEKIT_URL=wss://your-livekit-server.example.com
LIVEKIT_API_KEY=api-key-here
LIVEKIT_API_SECRET=api-secret-here

# ---- Backend ----
PORT=3001

# ---- Frontend (Vite) ----
# Optionnel. Vide en dev : Vite proxye /api vers localhost:3001 (vite.config.ts).
# En prod, mettre l'URL publique du backend, ex : https://api.example.com
VITE_API_BASE=