# ---- LiveKit (serveur uniquement — ne JAMAIS exposer côté frontend) ----
LIVEKIT_URL=wss://your-livekit-server.example.com
LIVEKIT_API_KEY=api-key-here
LIVEKIT_API_SECRET=api-secret-here

# ---- Backend ----
# Render fournit PORT automatiquement ; en local, défaut 3001.
PORT=3001
# Origine du frontend en production (CORS). Renseigner après déploiement Vercel.
# Ex : https://ton-frontend.vercel.app
WEB_ORIGIN=
# Mot de passe protégeant les tokens performer (canPublish). Requis en production :
# si aucun mot de passe configuré, /api/token renvoie 503 pour les performers. Les listeners restent publics.
PERFORMER_PASSWORD=change-me
# Optionnel : plusieurs mots de passe séparés par virgule (en plus du unique ci-dessus).
PERFORMER_PASSWORDS=guest-password,test-password

# ---- Frontend (Vite) ----
# Optionnel. Vide en dev : Vite proxye /api vers localhost:3001 (vite.config.ts).
# En prod, mettre l'URL publique du backend Render, ex : https://ton-backend.onrender.com
VITE_API_BASE=